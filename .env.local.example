# PostgreSQL connection string (Prisma + Neon).
# Get one free at https://neon.tech → New Project → Connect → copy the connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Stripe billing (dashboard.stripe.com). Billing UI is inert until set.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_WEBHOOK_SECRET_LOCAL=""
STRIPE_PRO_PRICE_ID=""
STRIPE_BUSINESS_PRICE_ID=""

# Auth.js v5 — generate with:  openssl rand -base64 32
AUTH_SECRET=""

# Base URL used for invitation links + OAuth callbacks
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (console.cloud.google.com → APIs & Services → Credentials).
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend (resend.com free tier) for workspace invitation emails.
RESEND_API_KEY=""

# Liveblocks (liveblocks.io free tier) for real-time collaboration.
# Secret key is required (auth endpoint + server broadcast). The public key is
# optional here because the client authenticates via /api/liveblocks-auth.
LIVEBLOCKS_SECRET_KEY=""
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=""

# Upstash Redis (console.upstash.com) for board cache + notification-count cache.
# Optional — the cache layer is a no-op (reads fall through to Postgres) when unset.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Anthropic (console.anthropic.com) for the AI features. Required to use AI;
# AI actions return a graceful error when unset.
ANTHROPIC_API_KEY=""

# UploadThing (uploadthing.com) for card attachments + avatar uploads.
# Optional — attachment upload UI is inert until set.
UPLOADTHING_TOKEN=""
