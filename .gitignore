# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/blob-report
/tests/e2e/.auth
.last-run.json

# next.js
/.next/
/out/

# serwist service worker (build artifacts — regenerated each build)
public/sw.js
public/sw.js.map
public/swe-worker-*.js
public/swe-worker-*.js.map

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env*.example

# local backups (never commit — may contain secrets)
*.bak
*.bak-*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# stale repo backup — an accidentally-embedded nested git repo (no .gitmodules).
# Untracked from the parent and ignored so it never re-enters lint/build/git.
/trello-replica-backup/
.claude/ 
.agents/ 
CLAUDE.md 
AGENTS.md 
skills-lock.json 
.gstack/
